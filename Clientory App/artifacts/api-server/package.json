{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --env-file-if-exists=../../.env.local --env-file-if-exists=../../.env --import tsx ./src/index.ts",
    "build": "node --env-file-if-exists=../../.env.local --env-file-if-exists=../../.env --import tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/genai": "^1.44.0",
    "@langfuse/client": "^5.3.0",
    "@langfuse/openai": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@sentry/node": "^10.53.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/billing": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "helmet": "^8.2.0",
    "openai": "^6.39.0",
    "resend": "^6.9.3",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.27.3",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "vitest": "^4.1.7"
  }
}
